# Local development values only. Never place real Vault tokens in committed files.
VITE_VAULT_URL=http://127.0.0.1:8200
VITE_VAULT_KV_MOUNT=firefox
VITE_VAULT_BASE_PATH=hvsecrets
VITE_VAULT_AUTH_MODE=token
VITE_VAULT_OIDC_AUTH_MOUNT=oidc
VITE_VAULT_OIDC_ROLE=hvsecrets

# Optional live integration test values.
# Provide VAULT_TOKEN in the shell only when running npm run test:integration.
# VAULT_ADDR can be omitted if VITE_VAULT_URL is set.
# VAULT_KV_MOUNT can be omitted if VITE_VAULT_KV_MOUNT is set.
# VAULT_BASE_PATH can be omitted if VITE_VAULT_BASE_PATH is set.
